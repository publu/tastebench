# --- audio / media (NEVER commit rights-sensitive or large media) ---
*.mp3
*.wav
*.flac
*.m4a
*.ogg
*.aac
*.opus
*.mp4
*.mov
*.avi
*.mkv
*.npz

# Exception — the ONLY audio in the repo: the author's own track, owned
# by the author and shipped solely as a test fixture so the demo is
# reproducible (see demo/README.md). The no-audio policy is about
# rights-sensitive / third-party media; this is neither.
!demo/level-up-v4.mp3

# --- secrets / credentials (NEVER commit) ---
.env
.env.*
env*.txt
*secret*
*token*
*.key
*.pem
credentials*
*.credentials

# --- model weights / caches (multi-GB, fetched by scripts/download_models.py) ---
models/
model-cache/
.model-cache/
.cache/
*.safetensors
*.bin
*.pt
*.ckpt

# --- worker workspace (created at runtime; media/reports are user content) ---
*.report.md
/workspace/

# --- python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- example work / scratch outputs ---
examples/_work/
*.analysis.json
*.analysis.md
.DS_Store

# visual/generated media — never commit (multimodal tool, BYO files)
*.png
*.jpg
*.jpeg
*.webp
*.bmp
*.gif
*.mp4
*.mov
*.mkv
*.webm
*.m4v
