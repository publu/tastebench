# --- audio / media (NEVER commit rights-sensitive or large media) ---
*.mp3
*.wav
*.flac
*.m4a
*.ogg
*.aac
*.opus
*.mp4
*.mov
*.avi
*.mkv
*.npz

# --- secrets / credentials (NEVER commit) ---
.env
.env.*
env*.txt
*secret*
*token*
*.key
*.pem
credentials*
