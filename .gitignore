# --- audio / media (NEVER commit rights-sensitive or large media) ---
*.mp3
*.wav
*.flac
*.m4a
*.ogg
*.aac
*.opus
*.mp4
*.mov
*.avi
*.mkv
*.npz

# --- secrets / credentials (NEVER commit) ---
.env
.env.*
env*.txt
*secret*
*token*
*.key
*.pem
credentials*
*.credentials

# --- model weights / caches (multi-GB, fetched by scripts/download_models.py) ---
models/
model-cache/
.model-cache/
.cache/
*.safetensors
*.bin
*.pt
*.ckpt

# --- worker workspace (created at runtime; media/reports are user content) ---
*.report.md
/workspace/

# --- python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- example work / scratch outputs ---
examples/_work/
*.analysis.json
*.analysis.md
.DS_Store

# visual/generated media — never commit (multimodal tool, BYO files)
*.png
*.jpg
*.jpeg
*.webp
*.bmp
*.gif
*.mp4
*.mov
*.mkv
*.webm
*.m4v

# --- the only media the repo ships (everything above stays ignored) ---
# These two sit at the very end so no pattern above can re-ignore them.
# The no-media policy is about rights-sensitive / third-party content;
# neither of these is that. See examples/README.md.
#  · level-up-v4.mp3 — the author's own track, the author's own work.
#  · kolm.mp4 — a tastebench web-QA capture of kolm.ai (a friend's
#    project), included with permission to demo the web path.
!examples/level-up-v4.mp3
!examples/kolm.mp4
